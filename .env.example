# ============================================
# Android Log Analyzer - LLM 配置文件
# ============================================
# 复制此文件为 .env 并填入你的配置
# ============================================

# ============================================
# 基础配置
# ============================================
# LLM API Key (必填，如需使用LLM功能)
LLM_API_KEY=your_api_key_here

# LLM Base URL (可选，使用第三方API时填写)
LLM_BASE_URL=

# 模型名称
LLM_MODEL=gpt-4o-mini

# 温度参数 (0.0-2.0，越低越确定，越高越有创造性)
LLM_TEMPERATURE=0.7

# 最大 Token 数
LLM_MAX_TOKENS=2000

# ============================================
# 预定义模型配置（取消注释即可使用）
# ============================================

# ---------- OpenAI 模型 ----------
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL=gpt-4-turbo
# LLM_MODEL=gpt-3.5-turbo

# ---------- 智谱 AI (Zhipu) / 智谱清言 ----------
# LLM_API_KEY=your_zhipu_api_key
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4
# LLM_MODEL=glm-4-plus
# LLM_MODEL=glm-4-flash
# LLM_MODEL=glm-3-turbo

# ---------- 通义千问 (Qwen) ----------
# LLM_API_KEY=your_qwen_api_key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# LLM_MODEL=qwen-turbo
# LLM_MODEL=qwen-max

# ---------- 文心一言 (ERNIE) ----------
# LLM_API_KEY=your_ernie_api_key
# LLM_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop
# LLM_MODEL=ernie-4.0
# LLM_MODEL=ernie-3.5

# ---------- 火山引擎 (Doubao) ----------
# LLM_API_KEY=your_doubao_api_key
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL=doubao-pro-32k
# LLM_MODEL=doubao-lite-32k

# ---------- 腾讯混元 (Hunyuan) ----------
# LLM_API_KEY=your_hunyuan_api_key
# LLM_BASE_URL=https://hunyuan.tencentcloudapi.com
# LLM_MODEL=hunyuan-lite
# LLM_MODEL=hunyuan-standard

# ---------- 其他兼容 OpenAI 格式的 API ----------
# LLM_API_KEY=your_api_key
# LLM_BASE_URL=https://your-custom-api.com/v1
# LLM_MODEL=your-model-name

# ============================================
# 向后兼容（旧版 OPENAI_ 前缀仍然支持）
# ============================================
# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini
