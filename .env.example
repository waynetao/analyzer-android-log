# ============================================
# Android Log Analyzer - LLM 配置文件
# ============================================
# 复制此文件为 .env 并填入你的配置
# ============================================

# ============================================
# 基础配置
# ============================================
# LLM API Key (必填，如需使用LLM功能)
LLM_API_KEY=your_api_key_here

# LLM Base URL (可选，使用第三方API时填写)
LLM_BASE_URL=

# 模型名称
LLM_MODEL=gpt-4o-mini

# 温度参数 (0.0-2.0，越低越确定，越高越有创造性)
LLM_TEMPERATURE=0.7

# 最大 Token 数
LLM_MAX_TOKENS=2000

# ============================================
# 预定义模型配置（取消注释即可使用）
# ============================================

# ---------- OpenAI 模型 ----------
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL=gpt-4-turbo
# LLM_MODEL=gpt-3.5-turbo

# ---------- 智谱 AI (Zhipu) / 智谱清言 ----------
# LLM_API_KEY=your_zhipu_api_key
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4
# LLM_MODEL=glm-4-plus
# LLM_MODEL=glm-4-flash
# LLM_MODEL=glm-3-turbo

# ---------- 通义千问 (Qwen) ----------
# LLM_API_KEY=your_qwen_api_key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# LLM_MODEL=qwen-turbo
# LLM_MODEL=qwen-max

# ---------- 文心一言 (ERNIE) ----------
# LLM_API_KEY=your_ernie_api_key
# LLM_BASE_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop
# LLM_MODEL=ernie-4.0
# LLM_MODEL=ernie-3.5

# ---------- 火山引擎 (Doubao) ----------
# LLM_API_KEY=your_doubao_api_key
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL=doubao-pro-32k
# LLM_MODEL=doubao-lite-32k

# ---------- 腾讯混元 (Hunyuan) ----------
# LLM_API_KEY=your_hunyuan_api_key
# LLM_BASE_URL=https://hunyuan.tencentcloudapi.com
# LLM_MODEL=hunyuan-lite
# LLM_MODEL=hunyuan-standard

# ---------- 其他兼容 OpenAI 格式的 API ----------
# LLM_API_KEY=your_api_key
# LLM_BASE_URL=https://your-custom-api.com/v1
# LLM_MODEL=your-model-name

# ============================================
# 场景定制配置（不同场景使用不同模型）
# ============================================
# 支持的场景:
#   - analysis: LLM 高级分析（复杂推理，建议使用大模型）
#   - bug_parser: Bug 描述解析（结构化提取）
#   - log_filter: 智能日志过滤
#   - exception_classifier: 异常分类
#   - evidence_matcher: 日志证据匹配
#
# 配置优先级: 场景特定配置 > 通用配置 > 旧版 OPENAI_ 配置
# ============================================
#
# ---------- 示例 1: 不同场景用不同模型 ----------
#
# # 分析场景用 GPT-4o（更智能）
# LLM_ANALYSIS_API_KEY=your_api_key
# LLM_ANALYSIS_BASE_URL=https://api.openai.com/v1
# LLM_ANALYSIS_MODEL=gpt-4o
# LLM_ANALYSIS_TEMPERATURE=0.7
# LLM_ANALYSIS_MAX_TOKENS=4000
#
# # Bug 解析用 GPT-4o-mini（更快更便宜）
# LLM_BUG_PARSER_API_KEY=your_api_key
# LLM_BUG_PARSER_BASE_URL=https://api.openai.com/v1
# LLM_BUG_PARSER_MODEL=gpt-4o-mini
# LLM_BUG_PARSER_TEMPERATURE=0.3
#
# # 日志过滤用 GLM-4-Flash
# LLM_LOG_FILTER_API_KEY=your_zhipu_key
# LLM_LOG_FILTER_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_LOG_FILTER_MODEL=glm-4-flash
#
# ---------- 示例 2: 所有场景用相同配置 ----------
#
# # 只需配置通用配置即可，所有场景都会继承
# # LLM_API_KEY=your_api_key
# # LLM_BASE_URL=https://api.openai.com/v1
# # LLM_MODEL=gpt-4o-mini
#
# ============================================
# 日志系统配置（可选）
# ============================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# 日志文件目录
LOG_DIR=logs

# 是否启用文件日志
LOG_ENABLE_FILE=true

# 是否启用控制台日志
LOG_ENABLE_CONSOLE=true

# 是否使用JSON格式（便于日志分析工具解析）
LOG_JSON_FORMAT=false

# ============================================
# OpenViking 配置（可选）
# ============================================
# OpenViking 是一个分层记忆系统，支持嵌入模型和 VLM 模型
# 参考文档: https://www.volcengine.com/docs/82379/2288685?lang=zh
# ============================================
#
# ---------- 嵌入模型配置（用于语义搜索） ----------
# OPENVIKING_EMBEDDING_BACKEND=volcengine
# OPENVIKING_EMBEDDING_API_KEY=<ARK_API_KEY>
# OPENVIKING_EMBEDDING_MODEL=doubao-embedding-vision
# OPENVIKING_EMBEDDING_API_BASE=https://ark.cn-beijing.volces.com/api/coding/v3
#
# ---------- VLM 模型配置（用于多模态处理） ----------
# OPENVIKING_VLM_BACKEND=volcengine
# OPENVIKING_VLM_API_KEY=<ARK_API_KEY>
# OPENVIKING_VLM_MODEL=doubao-seed-2.0-pro
# OPENVIKING_VLM_API_BASE=https://ark.cn-beijing.volces.com/api/coding/v3
# OPENVIKING_VLM_TEMPERATURE=0.1

# ============================================
# 向后兼容（旧版 OPENAI_ 前缀仍然支持）
# ============================================
# OPENAI_API_KEY=your_api_key_here
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o-mini
