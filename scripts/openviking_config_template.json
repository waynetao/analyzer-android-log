# OpenViking 配置文件模板
#
# 使用方式：
# 1. 复制此模板为 ~/.openviking/ov.conf
# 2. 填入真实的配置信息
# 3. 或使用环境变量 OPENVIKING_CONFIG_FILE 指定其他路径
#
# 完整文档：https://docs.openviking.ai/zh/
#
# 📌 重要提示：
# - 我们默认使用 Simple 模式，OpenViking 是增强选项
# - 若不需要 OpenViking，可以保持 memory_mode=simple，无需配置此文件
# - Simple 模式已完全可用，OpenViking 仅用于需要更高级功能时

{
  # Embedding 配置
  "embedding": {
    "dense": {
      # 提供商选择：volcengine（火山引擎）、openai、qwen（通义千问）等
      "provider": "volcengine",
      
      # API Key（需要配置真实值）
      "api_key": "YOUR_VOLCENGINE_API_KEY",
      
      # 模型名称
      "model": "doubao-embedding-v2",
      
      # 向量维度（根据模型调整）
      "dimension": 1024
    }
  },
  
  # VLM（视觉语言模型）配置（可选）
  "vlm": {
    "provider": "volcengine",
    "api_key": "YOUR_VOLCENGINE_API_KEY",
    "model": "doubao-pro-vision-2-25-12-15",
    "api_base": "https://ark.cn-beijing.volces.com/api/v3"
  },
  
  # Rerank 配置（可选）
  "rerank": {
    "provider": "volcengine",
    "api_key": "YOUR_VOLCENGINE_API_KEY",
    "model": "doubao-rerank-25-06-15"
  },
  
  # 存储配置
  "storage": {
    # 工作空间（数据存储位置）
    "workspace": "./openviking_data",
    
    # AGFS 配置
    "agfs": {
      # 后端：local（本地）、remote（服务器）
      "backend": "local"
    },
    
    # 向量数据库配置
    "vectordb": {
      "backend": "local"
    }
  }
}

